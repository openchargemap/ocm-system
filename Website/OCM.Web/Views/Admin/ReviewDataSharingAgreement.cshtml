@model OCM.Web.Models.AdminDataSharingAgreementReviewModel

@{
    ViewBag.Title = "Review Data Sharing Agreement";
    var statusMessage = TempData["StatusMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
    var currentImportJob = Model.CurrentImportJob;
    var importLogText = currentImportJob != null && currentImportJob.Logs.Any()
        ? string.Join(Environment.NewLine, currentImportJob.Logs.Select(log => $"[{log.TimestampUtc:HH:mm:ss}] {log.Level}: {log.Message}"))
        : "No log output yet.";
}

<h2>Review Data Sharing Agreement</h2>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert alert-success">@statusMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@Html.ValidationSummary(false, "", new { @class = "alert alert-danger" })

<div class="row">
    <div class="col-md-7">
        @using (Html.BeginForm("ReviewDataSharingAgreement", "Admin", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Review.AgreementId)
            @Html.HiddenFor(m => m.Review.DataProviderId)

            <div class="panel panel-default mb-3">
                <div class="panel-heading"><strong>Agreement Details</strong></div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Company</label>
                                @Html.TextBoxFor(m => m.Review.CompanyName, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.Review.CompanyName)
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Representative</label>
                                @Html.TextBoxFor(m => m.Review.RepresentativeName, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.Review.RepresentativeName)
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Contact Email</label>
                                @Html.TextBoxFor(m => m.Review.ContactEmail, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.Review.ContactEmail)
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Country</label>
                                @Html.DropDownListFor(m => m.Review.CountryId, (SelectList)ViewBag.CountryList, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.Review.CountryId)
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Website</label>
                        @Html.TextBoxFor(m => m.Review.WebsiteUrl, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Review.WebsiteUrl)
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Data Feed Type</label>
                                @Html.TextBoxFor(m => m.Review.DataFeedType, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.Review.DataFeedType)
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="checkbox" style="margin-top:30px;">
                                <label>
                                    @Html.CheckBoxFor(m => m.Review.ApproveImport) Approve import after saving
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Submitted Feed URL</label>
                        @Html.TextBoxFor(m => m.Review.SubmittedFeedUrl, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Review.SubmittedFeedUrl)
                    </div>
                    <div class="form-group">
                        <label>Submitted Credentials</label>
                        @Html.TextBoxFor(m => m.Review.SubmittedCredentials, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Review.SubmittedCredentials)
                        <span class="help-block">Keep this only if you want the review step to validate with the submitted secret value.</span>
                    </div>
                    <div class="form-group">
                        <label>Agreement Comment</label>
                        @Html.TextAreaFor(m => m.Review.AgreementComments, 3, 1, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Review.AgreementComments)
                    </div>
                </div>
            </div>

            <div class="panel panel-default mb-3">
                <div class="panel-heading"><strong>Final Stored OCPI Import Configuration</strong></div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Provider Name</label>
                                @Html.TextBoxFor(m => m.Review.ProviderName, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.Review.ProviderName)
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Output Prefix</label>
                                @Html.TextBoxFor(m => m.Review.OutputNamePrefix, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.Review.OutputNamePrefix)
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Linked Data Provider ID</label>
                                @Html.TextBoxFor(m => m.Review.DataProviderOcpiId, new { @class = "form-control", @readonly = "readonly" })
                                <span class="help-block">Created automatically when a linked data provider does not already exist.</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Default Operator ID</label>
                                @Html.TextBoxFor(m => m.Review.DefaultOperatorId, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.Review.DefaultOperatorId)
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Data Provider Status</label>
                        @Html.DropDownListFor(
                            m => m.Review.DataProviderStatusTypeId,
                            new SelectList(Model.AvailableDataProviderStatuses, "ID", "Title", Model.Review.DataProviderStatusTypeId),
                            "Select status",
                            new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Review.DataProviderStatusTypeId)
                    </div>
                    <div class="form-group">
                        <label>Locations Endpoint URL</label>
                        @Html.TextBoxFor(m => m.Review.LocationsEndpointUrl, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Review.LocationsEndpointUrl)
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Auth Header Key</label>
                                @Html.TextBoxFor(m => m.Review.AuthHeaderKey, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.Review.AuthHeaderKey)
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Auth Header Prefix</label>
                                @Html.TextBoxFor(m => m.Review.AuthHeaderValuePrefix, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.Review.AuthHeaderValuePrefix)
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Key Vault Secret Name</label>
                                @Html.TextBoxFor(m => m.Review.CredentialKey, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.Review.CredentialKey)
                                <span class="help-block">Optional unless the feed requires an authorization header.</span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        @Html.TextAreaFor(m => m.Review.Description, 3, 1, new { @class = "form-control" })
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="checkbox">
                                <label>@Html.CheckBoxFor(m => m.Review.IsEnabled) Enabled</label>
                            </div>
                            <div class="checkbox">
                                <label>@Html.CheckBoxFor(m => m.Review.IsAutoRefreshed) Auto refreshed</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="checkbox">
                                <label>@Html.CheckBoxFor(m => m.Review.IsProductionReady) Production ready</label>
                            </div>
                            <div class="checkbox">
                                <label>@Html.CheckBoxFor(m => m.Review.AllowDuplicatePOIWithDifferentOperator) Allow duplicate POI with different operator</label>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Operator Mappings</label>
                        @Html.TextAreaFor(m => m.Review.OperatorMappingsText, 8, 1, new { @class = "form-control", placeholder = "Operator Name=1234" })
                        <span class="help-block">One mapping per line in the format <code>Operator Name=OperatorId</code>.</span>
                    </div>
                    <div class="form-group">
                        <label>Excluded Location IDs</label>
                        @Html.TextAreaFor(m => m.Review.ExcludedLocationIdsText, 5, 1, new { @class = "form-control", placeholder = "LOC001" })
                        <span class="help-block">One location ID per line.</span>
                    </div>
                    <div class="clearfix">
                        <button type="submit" class="btn btn-primary">Save Review and Stored Config</button>

                        <button type="submit"
                                class="btn btn-danger"
                                style="float:right;"
                                formaction="@Url.Action("DeleteDataSharingAgreement", "Admin")"
                                formmethod="post"
                                formnovalidate="formnovalidate"
                                name="id"
                                value="@Model.Agreement.ID"
                                onclick="return confirm('Delete this data sharing agreement? Linked data providers will be unlinked, but not deleted.');">
                            Delete Agreement
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="col-md-5">
        <div class="panel panel-default mb-3">
            <div class="panel-heading"><strong>Linked Data Provider</strong></div>
            <div class="panel-body">
                @if (Model.DataProvider != null)
                {
                    <dl class="dl-horizontal">
                        <dt>Title</dt>
                        <dd>@Model.DataProvider.Title</dd>
                        <dt>ID</dt>
                        <dd>@Model.DataProvider.ID</dd>
                        <dt>Status</dt>
                        <dd>
                            @if (!string.IsNullOrWhiteSpace(Model.DataProvider.DataProviderStatusType?.Title))
                            {
                                @Model.DataProvider.DataProviderStatusType.Title
                            }
                            else
                            {
                                <span class="text-muted">Not set</span>
                            }
                        </dd>
                        <dt>Approval</dt>
                        <dd>
                            @if (Model.IsApproved)
                            {
                                <span class="label label-success">Approved</span>
                            }
                            else
                            {
                                <span class="label label-warning">Pending Review</span>
                            }
                        </dd>
                        <dt>Last Import</dt>
                        <dd>@(Model.DataProvider.DateLastImported?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</dd>
                    </dl>
                }
                else
                {
                    <div class="alert alert-warning">A linked data provider will be created when the review is saved.</div>
                }
            </div>
        </div>

        <div class="panel panel-default mb-3">
            <div class="panel-heading"><strong>OCPI Feed Preview</strong></div>
            <div class="panel-body">
                @if (Model.ValidationPreview != null && Model.ValidationPreview.Errors.Any())
                {
                    <div class="alert alert-danger">
                        <strong>Preview failed</strong>
                        <ul class="mb-0">
                            @foreach (var error in Model.ValidationPreview.Errors)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    </div>
                }
                else if (Model.ValidationPreview != null)
                {
                    <p><strong>Locations:</strong> @Model.ValidationPreview.LocationCount</p>
                    <p><strong>EVSEs:</strong> @Model.ValidationPreview.EvseCount</p>
                    <p><strong>Resolved endpoint:</strong> <code>@(Model.ValidationPreview.ResolvedLocationsEndpointUrl ?? Model.Review.LocationsEndpointUrl ?? Model.Agreement.DataFeedURL)</code></p>
                    <p><strong>Authorization:</strong> @(Model.ValidationPreview.ResolvedAuthHeaderDisplayValue ?? "None")</p>

                    if (Model.ValidationPreview.Warnings.Any())
                    {
                        <div class="alert alert-warning">
                            <ul class="mb-0">
                                @foreach (var warning in Model.ValidationPreview.Warnings)
                                {
                                    <li>@warning</li>
                                }
                            </ul>
                        </div>
                    }

                    if (Model.ValidationPreview.SampleLocations.Any())
                    {
                        <h5>Sample Locations</h5>
                        <ul>
                            @foreach (var name in Model.ValidationPreview.SampleLocations)
                            {
                                <li>@name</li>
                            }
                        </ul>
                    }
                }
            </div>
        </div>

        <div id="agreement-import-monitor" class="panel panel-default mb-3">
            <div class="panel-heading"><strong>Manual Import</strong></div>
            <div class="panel-body">
                <p class="text-muted">Queue the stored import configuration for this agreement and monitor progress live here.</p>

                @using (Html.BeginForm("QueueDataSharingAgreementImport", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.Hidden("id", Model.Agreement.ID)
                    <button type="submit" class="btn btn-success">Queue Import</button>
                }

                @using (Html.BeginForm("PreviewDataSharingAgreementImport", "Admin", FormMethod.Post, new { style = "display:inline-block; margin-left:10px;" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.Hidden("id", Model.Agreement.ID)
                    <button type="submit" class="btn btn-default">Queue Preview</button>
                }

                @if (currentImportJob != null)
                {
                    <p>
                        <a href="@(Url.Action("ReviewDataSharingAgreement", "Admin", new { id = Model.Agreement.ID, jobId = currentImportJob.JobId }) + "#agreement-import-monitor")" class="btn btn-link btn-sm" style="padding-left:0;">Direct link to this job monitor</a>
                    </p>

                    <hr />
                    <dl class="dl-horizontal small">
                        <dt>Job</dt>
                        <dd><code>@currentImportJob.JobId</code></dd>
                        <dt>Mode</dt>
                        <dd>@currentImportJob.ModeText</dd>
                        <dt>Provider</dt>
                        <dd>@(currentImportJob.ProviderName ?? Model.Review.ProviderName ?? "Pending")</dd>
                        <dt>Status</dt>
                        <dd><span id="agreement-import-status" class="label @(currentImportJob.Status == OCM.Web.Models.ImportJobStatus.Completed ? "label-success" : currentImportJob.Status == OCM.Web.Models.ImportJobStatus.Failed ? "label-danger" : "label-info")">@currentImportJob.StatusText</span></dd>
                        <dt>Message</dt>
                        <dd id="agreement-import-status-message">@currentImportJob.StatusMessage</dd>
                        <dt>Queued</dt>
                        <dd>@currentImportJob.QueuedUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC</dd>
                        @if (currentImportJob.StartedUtc.HasValue)
                        {
                            <dt>Started</dt>
                            <dd>@currentImportJob.StartedUtc.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</dd>
                        }
                        @if (currentImportJob.CompletedUtc.HasValue)
                        {
                            <dt>Completed</dt>
                            <dd>@currentImportJob.CompletedUtc.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</dd>
                        }
                    </dl>

                    if (!string.IsNullOrWhiteSpace(currentImportJob.LastError))
                    {
                        <div id="agreement-import-error" class="alert alert-danger small">@currentImportJob.LastError</div>
                    }
                    else
                    {
                        <div id="agreement-import-error" class="alert alert-danger small" style="display:none;"></div>
                    }

                    <pre id="agreement-import-log" class="small" style="max-height:320px; overflow:auto; white-space:pre-wrap;">@importLogText</pre>

                    @if (currentImportJob.Mode == OCM.Web.Models.ImportJobMode.Preview && currentImportJob.PreviewSummary != null)
                    {
                        <div id="agreement-import-preview-summary" class="panel panel-info" style="margin-top:15px;">
                            <div class="panel-heading"><strong>Preview Summary</strong></div>
                            <div class="panel-body small">
                                <p><strong>Source items:</strong> @currentImportJob.PreviewSummary.SourceItemCount</p>
                                <p><strong>Preview processed:</strong> @currentImportJob.PreviewSummary.PreviewItemCount / @currentImportJob.PreviewSummary.PreviewItemLimit</p>
                                <ul>
                                    <li>Added: @currentImportJob.PreviewSummary.AddedCount</li>
                                    <li>Updated: @currentImportJob.PreviewSummary.UpdatedCount</li>
                                    <li>Unchanged: @currentImportJob.PreviewSummary.UnchangedCount</li>
                                    <li>Duplicates: @currentImportJob.PreviewSummary.DuplicateCount</li>
                                    <li>Low quality: @currentImportJob.PreviewSummary.LowDataQualityCount</li>
                                    <li>Delisted: @currentImportJob.PreviewSummary.DelistedCount</li>
                                </ul>

                                @if (currentImportJob.PreviewSummary.AddedItems.Any())
                                {
                                    <h5>Sample Added Items</h5>
                                    <ul>
                                        @foreach (var item in currentImportJob.PreviewSummary.AddedItems)
                                        {
                                            <li>@(item.Title ?? item.Reference ?? "Untitled") @if (!string.IsNullOrWhiteSpace(item.Address)) { <span class="text-muted">- @item.Address</span> } @if (!string.IsNullOrWhiteSpace(item.Reference)) { <span class="text-muted">(@item.Reference)</span> }</li>
                                        }
                                    </ul>
                                }

                                @if (currentImportJob.PreviewSummary.UpdatedItems.Any())
                                {
                                    <h5>Sample Updated Items</h5>
                                    <ul>
                                        @foreach (var item in currentImportJob.PreviewSummary.UpdatedItems)
                                        {
                                            <li>@(item.OcmId.HasValue ? $"OCM-{item.OcmId.Value}: " : string.Empty)@(item.Title ?? item.Reference ?? "Untitled") @if (!string.IsNullOrWhiteSpace(item.Address)) { <span class="text-muted">- @item.Address</span> } @if (!string.IsNullOrWhiteSpace(item.Reference)) { <span class="text-muted">(@item.Reference)</span> }</li>
                                        }
                                    </ul>
                                }

                                @if (currentImportJob.PreviewSummary.DelistedItems.Any())
                                {
                                    <h5>Sample Delisted Items</h5>
                                    <ul>
                                        @foreach (var item in currentImportJob.PreviewSummary.DelistedItems)
                                        {
                                            <li>@(item.OcmId.HasValue ? $"OCM-{item.OcmId.Value}: " : string.Empty)@(item.Title ?? item.Reference ?? "Untitled") @if (!string.IsNullOrWhiteSpace(item.Address)) { <span class="text-muted">- @item.Address</span> }</li>
                                        }
                                    </ul>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No manual imports have been queued for this agreement yet.</p>
                }
            </div>
        </div>

        @if (Model.ValidationPreview != null && Model.ValidationPreview.DiscoveredOperators.Any())
        {
            <div class="panel panel-default mb-3">
                <div class="panel-heading"><strong>Discovered Operators</strong></div>
                <div class="panel-body">
                    <ul>
                        @foreach (var item in Model.ValidationPreview.DiscoveredOperators)
                        {
                            <li>@item.Name (@item.LocationCount location(s))</li>
                        }
                    </ul>
                </div>
            </div>
        }

        @if (Model.ValidationPreview != null && Model.ValidationPreview.DiscoveryLog.Any())
        {
            <div class="panel panel-default mb-3">
                <div class="panel-heading"><strong>Discovery Log</strong></div>
                <div class="panel-body">
                    <ul class="small">
                        @foreach (var message in Model.ValidationPreview.DiscoveryLog)
                        {
                            <li>@message</li>
                        }
                    </ul>
                </div>
            </div>
        }

        <div class="panel panel-default">
            <div class="panel-heading"><strong>Stored Import Config</strong></div>
            <div class="panel-body">
                @if (string.IsNullOrWhiteSpace(Model.ImportConfig))
                {
                    <p class="text-muted">No stored OCPI config yet.</p>
                }
                else
                {
                    <pre class="small mb-0">@Model.ImportConfig</pre>
                }
            </div>
        </div>
    </div>

@if (currentImportJob != null && currentImportJob.IsActive)
{
    <script>
        (function () {
            var logElement = document.getElementById('agreement-import-log');
            var statusElement = document.getElementById('agreement-import-status');
            var statusMessageElement = document.getElementById('agreement-import-status-message');
            var errorElement = document.getElementById('agreement-import-error');

            if (!logElement || !window.EventSource) {
                return;
            }

            logElement.textContent = '';

            function getStatusClass(status) {
                if (status === 'Completed') {
                    return 'label label-success';
                }

                if (status === 'Failed') {
                    return 'label label-danger';
                }

                return 'label label-info';
            }

            function appendLogLine(line) {
                if (logElement.textContent && logElement.textContent !== 'No log output yet.') {
                    logElement.textContent += '\n';
                }

                logElement.textContent += line;
                logElement.scrollTop = logElement.scrollHeight;
            }

            var eventSource = new EventSource('@Url.Action("StreamDataSharingAgreementImportLogs", "Admin", new { jobId = currentImportJob.JobId })');

            eventSource.addEventListener('log', function (event) {
                var payload = JSON.parse(event.data);
                if (!payload.logEntry) {
                    return;
                }

                appendLogLine('[' + payload.logEntry.timestampUtc.substring(11, 19) + '] ' + payload.logEntry.level + ': ' + payload.logEntry.message);
            });

            eventSource.addEventListener('status', function (event) {
                var payload = JSON.parse(event.data);

                if (statusElement && payload.status) {
                    statusElement.textContent = payload.status;
                    statusElement.className = getStatusClass(payload.status);
                }

                if (statusMessageElement) {
                    statusMessageElement.textContent = payload.statusMessage || '';
                }

                if (errorElement) {
                    if (payload.lastError) {
                        errorElement.style.display = 'block';
                        errorElement.textContent = payload.lastError;
                    } else {
                        errorElement.style.display = 'none';
                        errorElement.textContent = '';
                    }
                }

                if ((payload.status === 'Completed' || payload.status === 'Failed') && payload.mode === 'Preview' && payload.previewSummary) {
                    window.location.reload();
                    return;
                }

                if (payload.status === 'Completed' || payload.status === 'Failed') {
                    eventSource.close();
                }
            });

            eventSource.onerror = function () {
                eventSource.close();
            };
        })();
    </script>
}
</div>
